@page "/database-unlock"
@using Nine.Infrastructure.Services
@using Nine.Application.Services
@using ElectronNET.API
@inject DatabaseUnlockState UnlockState
@inject DatabaseUnlockService UnlockService
@implements IDisposable
@rendermode InteractiveServer

<div class="database-unlock-container">
    <div class="unlock-card">
        @if (UnlockState.IsUnsupportedSchema)
        {
            <!-- Unsupported Schema State -->
            <div class="text-center mb-4">
                <i class="bi bi-database-x" style="font-size: 4rem; color: var(--bs-warning);"></i>
            </div>

            <h2 class="text-center mb-3">Database Cannot Be Upgraded</h2>
            <p class="text-center text-muted mb-4">
                Your database is from an older version that cannot be automatically upgraded to Nine.
                Your data has been backed up and is safe.
            </p>

            @if (!string.IsNullOrEmpty(UnlockState.UnsupportedSchemaBackupPath))
            {
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-shield-check"></i>
                    <strong>Your data is safe.</strong> A backup has been preserved at:
                    <div class="mt-2 font-monospace small bg-white bg-opacity-50 p-2 rounded">
                        @UnlockState.UnsupportedSchemaBackupPath
                    </div>
                </div>
            }

            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i>
                A future version of Nine will include an import wizard to migrate your data from this backup.
            </div>

            <button type="button"
                    class="btn btn-primary w-100 mb-3"
                    @onclick="ShowStartFreshConfirmation">
                <i class="bi bi-arrow-clockwise"></i> Start with New Database
            </button>
        }
        else if (!unlockSuccessful)
        {
            <!-- Unlock Form -->
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock" style="font-size: 4rem; color: var(--bs-primary);"></i>
            </div>
            
            <h2 class="text-center mb-3">Database Locked</h2>
            <p class="text-center text-muted mb-4">
                Your database is encrypted. Please enter your password to unlock it.
            </p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                </div>
            }

            <EditForm Model="@this" OnValidSubmit="HandleUnlock">
                <div class="mb-3">
                    <label for="password" class="form-label">Database Password</label>
                    <div class="input-group">
                        <input type="@(showPassword ? "text" : "password")" 
                               class="form-control" 
                               id="password"
                               @bind="password"
                               placeholder="Enter your password"
                               disabled="@isUnlocking"
                               required />
                        <button class="btn btn-outline-secondary" 
                                type="button"
                                @onclick="() => showPassword = !showPassword"
                                disabled="@isUnlocking">
                            <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <div class="form-text">
                        This is the password you used when encrypting the database.
                    </div>
                </div>

                <button type="submit" 
                        class="btn btn-primary w-100" 
                        disabled="@(isUnlocking || string.IsNullOrWhiteSpace(password))">
                    @if (isUnlocking)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span class="ms-2">Unlocking...</span>
                    }
                    else
                    {
                        <i class="bi bi-unlock"></i>
                        <span class="ms-2">Unlock Database</span>
                    }
                </button>
            </EditForm>

            <!-- Divider for "Forgot Password" section -->
            <div class="my-4">
                <hr />
                <div class="text-center text-muted small">
                    Can't remember your password?
                </div>
            </div>

            <!-- Start Fresh Button -->
            <button type="button"
                    class="btn btn-outline-warning w-100"
                    @onclick="ShowStartFreshConfirmation"
                    disabled="@isUnlocking">
                <i class="bi bi-arrow-clockwise"></i> Start with New Database
            </button>

            <div class="mt-4 text-center">
                <small class="text-muted">
                    <i class="bi bi-info-circle"></i>
                    Your password is stored securely in the system keychain after successful unlock.
                </small>
            </div>
        }
        else
        {
            <!-- Success State -->
            <div class="text-center mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            </div>

            <h2 class="text-center mb-3 text-success">Password Saved!</h2>
            <p class="text-center text-muted mb-4">
                Your password has been verified and stored securely in the system keychain.
            </p>

            <div class="alert alert-info text-center" role="alert">
                <div class="mb-2">
                    @if (UnlockState.RequiresRestartAfterUnlock)
                    {
                        <strong>Nine is restarting in</strong>
                    }
                    else
                    {
                        <strong>Application reloading in</strong>
                    }
                </div>
                <div class="display-4 fw-bold text-primary">@countdownSeconds</div>
                <div class="mt-2 text-muted small">seconds</div>
            </div>

            @if (UnlockState.RequiresRestartAfterUnlock)
            {
                <button class="btn btn-warning w-100" @onclick="() => RestartNow()">
                    <i class="bi bi-power"></i> Restart Now
                </button>
                <div class="mt-3 text-center">
                    <small class="text-muted">
                        Nine will quit and you can relaunch it to complete the database update.
                    </small>
                </div>
            }
            else
            {
                <button class="btn btn-primary w-100" @onclick="() => RestartNow()">
                    <i class="bi bi-arrow-clockwise"></i> Reload Now
                </button>
                <div class="mt-3 text-center">
                    <small class="text-muted">
                        The application will reload to open your database.
                    </small>
                </div>
            }
        }
    </div>
</div>

<!-- Confirmation Modal for Start Fresh -->
@if (showStartFreshModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle-fill"></i> Start with New Database?
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showStartFreshModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (UnlockState.IsUnsupportedSchema)
                    {
                        <p><strong>This will:</strong></p>
                        <ul>
                            <li>Leave the current database in place for further recovery attempts.</li>
                            <li>Allow you to start with a new setup by creating a new account.</li>
                            <li>Import existing data from another valid database if available.</li>
                        </ul>
                        @if (!string.IsNullOrEmpty(UnlockState.UnsupportedSchemaBackupPath))
                        {
                            <p class="mt-3"><strong>Your data backup is already safely preserved at:</strong></p>
                            <p class="font-monospace small bg-light p-2 rounded">
                                @UnlockState.UnsupportedSchemaBackupPath
                            </p>
                        }
                        @* <p class="text-muted small">
                            A future version of Nine will include an import wizard to migrate your data from this backup.
                        </p> *@
                    }
                    else
                    {
                        <p><strong>This will:</strong></p>
                        <ul>
                            <li>Archive your encrypted database to the Backups folder</li>
                            <li>Create a fresh, empty database</li>
                            <li>Allow you to start over with no data</li>
                        </ul>
                        <p class="mt-3"><strong>Your encrypted database will be saved to:</strong></p>
                        <p class="font-monospace small bg-light p-2 rounded">
                            @GetArchivePath()
                        </p>
                        <p class="text-muted small">
                            You can download this file for later decryption attempts or professional data recovery.
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(startFreshError))
                    {
                        <div class="alert alert-danger mt-3">
                            <i class="bi bi-exclamation-triangle-fill"></i> @startFreshError
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" 
                            class="btn btn-secondary" 
                            @onclick="() => showStartFreshModal = false"
                            disabled="@isStartingFresh">
                        Cancel
                    </button>
                    <button type="button" 
                            class="btn btn-warning" 
                            @onclick="HandleStartFresh"
                            disabled="@isStartingFresh">
                        @if (isStartingFresh)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span class="ms-2">Processing...</span>
                        }
                        else
                        {
                            <i class="bi bi-arrow-clockwise"></i>
                            <span class="ms-2">Yes, Start Fresh</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .database-unlock-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .unlock-card {
        background: white;
        padding: 2rem;
        border-radius: 1rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        max-width: 450px;
        width: 100%;
    }
</style>

@code {
    private string password = string.Empty;
    private string? errorMessage;
    private bool isUnlocking = false;
    private bool showPassword = false;
    private bool unlockSuccessful = false;
    private int countdownSeconds = 5;
    private System.Threading.Timer? countdownTimer;
    
    // Start Fresh modal state
    private bool showStartFreshModal = false;
    private bool isStartingFresh = false;
    private string? startFreshError = null;

    private async Task HandleUnlock()
    {
        errorMessage = null;
        isUnlocking = true;

        try
        {
            // When a restart is required after unlock, the target DB doesn't exist yet.
            // Verify against the encrypted sibling to avoid SQLite silently creating an
            // empty encrypted file at the target path (which causes version-scan to skip
            // the copy on relaunch, discarding the user's actual data).
            var verifyConnectionString = (UnlockState.RequiresRestartAfterUnlock && !string.IsNullOrEmpty(UnlockState.EncryptedSiblingPath))
                ? $"Data Source={UnlockState.EncryptedSiblingPath}"
                : UnlockState.ConnectionString!;

            var (success, error) = await UnlockService.UnlockDatabaseAsync(
                verifyConnectionString,
                password);

            if (success)
            {
                // Mark unlock complete
                UnlockState.NeedsUnlock = false;
                UnlockState.NotifyUnlockSuccess();
                
                // Show success message with countdown
                unlockSuccessful = true;
                StartCountdown();
            }
            else
            {
                errorMessage = error;
                password = string.Empty; // Clear password on failure
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            isUnlocking = false;
        }
    }

    private void StartCountdown()
    {
        countdownTimer = new System.Threading.Timer(_ =>
        {
            countdownSeconds--;
            InvokeAsync(StateHasChanged);

            if (countdownSeconds <= 0)
            {
                countdownTimer?.Dispose();
                InvokeAsync(() => RestartNow("timer-elapsed"));
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void RestartNow(string trigger = "button-click")
    {
        Console.WriteLine($"[DatabaseUnlock] RestartNow triggered by: {trigger}");
        countdownTimer?.Dispose();
        Electron.App.Relaunch();
        Electron.App.Exit();
    }

    private void ShowStartFreshConfirmation()
    {
        Console.WriteLine($"[DatabaseUnlock] Opening modal. DatabasePath: {UnlockState.DatabasePath}");
        showStartFreshModal = true;
        startFreshError = null;
    }

    private string GetArchivePath()
    {
        if (string.IsNullOrEmpty(UnlockState.DatabasePath))
            return "Backups/[database-name].[timestamp].encrypted.db";
            
        var dbFileNameWithoutExt = Path.GetFileNameWithoutExtension(UnlockState.DatabasePath);
        var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
        return $"Backups/{dbFileNameWithoutExt}.{timestamp}.encrypted.db";
    }

    private async Task HandleStartFresh()
    {
        Console.WriteLine("[DatabaseUnlock] HandleStartFresh called");
        startFreshError = null;
        isStartingFresh = true;

        try
        {
            // Validate database path exists
            if (string.IsNullOrEmpty(UnlockState.DatabasePath))
            {
                Console.WriteLine("[DatabaseUnlock] ERROR: Database path is null or empty");
                startFreshError = "Database path is not set. Cannot proceed.";
                isStartingFresh = false;
                return;
            }

            // When unsupported schema, Program.cs already quarantined all app_v*.db files
            // (renamed to .unsupported_schema) and DatabaseService already saved a backup at
            // UnsupportedSchemaBackupPath. No archiving needed — restart immediately so
            // Program.cs finds no app_v*.db and initializes a fresh database.
            if (UnlockState.IsUnsupportedSchema)
            {
                Console.WriteLine("[DatabaseUnlock] Unsupported schema — quarantine already done, restarting fresh.");
                Electron.App.Relaunch();
                Electron.App.Exit();
                return;
            }

            Console.WriteLine($"[DatabaseUnlock] Calling StartWithNewDatabaseAsync for: {UnlockState.DatabasePath}");
            var (success, archivedPath, error) = await UnlockService.StartWithNewDatabaseAsync(
                UnlockState.DatabasePath);

            if (success)
            {
                Console.WriteLine($"[DatabaseUnlock] Success! Archived to: {archivedPath}");
                Console.WriteLine("[DatabaseUnlock] Restarting application...");
                
                // Restart Electron app to trigger Program.cs database detection workflow
                // This will detect no database exists and start fresh setup
                Electron.App.Relaunch();
                Electron.App.Exit();
            }
            else
            {
                Console.WriteLine($"[DatabaseUnlock] Failed: {error}");
                startFreshError = error;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DatabaseUnlock] Exception: {ex.Message}");
            startFreshError = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            isStartingFresh = false;
        }
    }

    public void Dispose()
    {
        countdownTimer?.Dispose();
    }
}
